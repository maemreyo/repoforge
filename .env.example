# RepoForge runtime configuration
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# The managed runtime worker auto-loads a .env file next to --config or in
# the current working directory (whichever it finds first), without
# overriding a variable already exported in the shell.
#
# CONTROL_PLANE_API_KEY: required when connecting to a control plane.
# CONTROL_PLANE_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
