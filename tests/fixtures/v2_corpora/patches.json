{
  "schema_version": 1,
  "corpus": "patches",
  "cases": [
    {
      "id": "git-diff-add-line",
      "input": {
        "patch": "diff --git a/README.md b/README.md\n--- a/README.md\n+++ b/README.md\n@@ -1 +1,2 @@\n # Demo\n+Added.\n"
      },
      "expected": {
        "changed_paths": ["README.md"],
        "wrong_target": false
      },
      "metadata": {
        "producer": "git-diff",
        "format": "unified"
      }
    },
    {
