      "input": {
        "patch": "diff --git a/src/a.py b/src/a.py\n--- a/src/a.py\n+++ b/src/a.py\n@@ -1 +1 @@\n-A = 1\n+A = 2\n@@ -5 +5 @@\n-B = 1\n+B = 2\n"
      },
      "expected": {
        "changed_paths": ["src/a.py"],
        "wrong_target": false
      },
      "metadata": {
        "producer": "gpt",
        "format": "unified"
      }
    },
    {
